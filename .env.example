# Copy this to .env and fill in your values
# For local dev: set these in a .env file
# For Vercel:   set these in Vercel Dashboard → Project → Environment Variables

# ─── Required ─────────────────────────────────────────────
ADMIN_SECRET=nexus-admin-2025
ADMIN_USERNAME=admin
ADMIN_PASSWORD=nexus2025

# ─── AI Generation ────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Persistent Storage (Vercel KV / Upstash Redis) ───────
# Get these from Vercel Dashboard → Storage → KV → Connect
KV_REST_API_URL=https://your-kv.upstash.io
KV_REST_API_TOKEN=your_kv_token_here

# ─── Frontend (optional override) ─────────────────────────
VITE_API_URL=http://localhost:8000
